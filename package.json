{
  "name": "simplesfique",
  "version": "0.1.0",
  "private": true,
  "main": "electron.js",
  "scripts": {
    "serve": "vue-cli-service serve",
    "build": "vue-cli-service build",
    "lint": "vue-cli-service lint",
    "dev": "concurrently \"npm run serve\" \"npm run electron-dev\"",
    "electron-dev": "node -e \"const http=require('http');const t=setInterval(()=>{http.get('http://localhost:8080',r=>{clearInterval(t);clearTimeout(o);process.exit(0)}).on('error',()=>{})},500);const o=setTimeout(()=>{clearInterval(t);process.exit(1)},60000)\" && NODE_ENV=development npx electron .",
    "electron-build": "npm run build && npx electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky",
    "pendencias": "node scripts/pendencias-php.js gerar",
    "pendencias:add": "node scripts/pendencias-php.js add",
    "pendencias:status": "node scripts/pendencias-php.js status",
    "test:api": "node scripts/api-smoke-test.js",
    "test:api:php": "node scripts/api-smoke-test.js --php-only",
    "test:api:thorse": "node scripts/api-smoke-test.js --thorse-only"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1043.0",
    "@aws-sdk/s3-request-presigner": "^3.1043.0",
    "@devindex/vue-mask": "^2.0.3",
    "@guolao/vue-monaco-editor": "^1.6.0",
    "@mdi/font": "5.9.55",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@primeuix/themes": "^1.2.1",
    "@tailwindcss/postcss": "^4.1.11",
    "aos": "^2.3.4",
    "apexcharts": "^5.3.6",
    "autoprefixer": "^10.4.21",
    "aws-sdk": "^2.1693.0",
    "axios": "^1.12.2",
    "core-js": "^3.8.3",
    "html2pdf.js": "^0.12.1",
    "html5-qrcode": "^2.3.8",
    "lucide-vue-next": "^0.525.0",
    "monaco-editor": "^0.55.1",
    "node-forge": "^1.3.3",
    "numeric": "^1.2.6",
    "particles.js": "^2.0.0",
    "pinia": "^3.0.3",
    "pinia-plugin-persistedstate": "^4.4.1",
    "postcss": "^8.5.6",
    "primevue": "^4.3.6",
    "roboto-fontface": "*",
    "vue": "^3.2.13",
    "vue-router": "^4.0.3",
    "vue3-apexcharts": "^1.10.0",
    "vue3-toastify": "^0.2.8",
    "vuedraggable": "^4.1.0",
    "vuetify": "^3.0.0-beta.0",
    "webfontloader": "^1.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.12.16",
    "@babel/eslint-parser": "^7.12.16",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/cli-plugin-babel": "~5.0.0",
    "@vue/cli-plugin-eslint": "~5.0.0",
    "@vue/cli-plugin-router": "~5.0.0",
    "@vue/cli-service": "~5.0.0",
    "@vue/test-utils": "^2.4.10",
    "concurrently": "^10.0.1",
    "electron": "^39.1.1",
    "eslint": "^7.32.0",
    "eslint-plugin-vue": "^8.0.3",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "sass": "^1.32.7",
    "sass-loader": "^12.0.0",
    "tailwindcss": "^4.1.11",
    "vitest": "^4.1.8",
    "vue-cli-plugin-vuetify": "~2.5.8",
        "webpack-plugin-vuetify": "^3.1.1"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true,
      "browser": true,
      "jest": true
    },
    "extends": [
      "plugin:vue/vue3-essential",
      "eslint:recommended"
    ],
    "parserOptions": {
      "parser": "@babel/eslint-parser"
    },
    "globals": {
      "particlesJS": "readonly",
      "globalThis": "readonly"
    },
    "ignorePatterns": [
      "src/components/particle/**",
      "src/examples/**"
    ],
    "rules": {}
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ]
}
