    "particles.js": "^2.0.0",
    "pinia": "^3.0.3",
    "pinia-plugin-persistedstate": "^4.4.1",
    "postcss": "^8.5.6",
    "primevue": "^4.3.6",
    "roboto-fontface": "*",
